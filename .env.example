# AMP API settings
AMP_BASE_URL=http://127.0.0.1:8080
# AMPAPI_Python (cc-ampapi) credentials
AMP_USERNAME=replace_with_amp_username
AMP_PASSWORD=replace_with_amp_password
# Periodic full reconcile interval in seconds. Set to 0 to disable.
PERIODIC_SYNC_SECONDS=10

# Cloudflare settings
CLOUDFLARE_API_TOKEN=replace_with_cloudflare_api_token
CLOUDFLARE_ZONE_ID=replace_with_zone_id_for_cobyas_xyz

# DNS constraints
ALLOWED_DOMAIN=cobyas.xyz
DNS_TTL=60
# Keep false for game traffic. Cloudflare proxy does not support most game protocols.
DNS_PROXIED=false

# Fallback target hostname if AMP instance data does not include one.
# Usually your game node's public DNS name, for example: node1.cobyas.xyz
DEFAULT_TARGET=

# Optional: comma-separated list of instance names to ignore
IGNORE_INSTANCE_NAMES=
