# AMP API settings
AMP_BASE_URL=http://127.0.0.1:8080
# AMPAPI_Python (cc-ampapi) credentials
AMP_USERNAME=replace_with_amp_username
AMP_PASSWORD=replace_with_amp_password
# Periodic full reconcile interval in seconds. Set to 0 to disable.
PERIODIC_SYNC_SECONDS=10

# Cloudflare settings
CLOUDFLARE_API_TOKEN=replace_with_cloudflare_api_token
CLOUDFLARE_ZONE_ID=replace_with_zone_id_for_cobyas_xyz

# DNS constraints
ALLOWED_DOMAIN=cobyas.xyz
DNS_TTL=60
# Keep false for game traffic. Cloudflare proxy does not support most game protocols.
DNS_PROXIED=false

# Fallback target hostname if AMP instance data does not include one.
# Usually your game node's public DNS name, for example: node1.cobyas.xyz
DEFAULT_TARGET=

# Optional: use an existing Cloudflare DNS record (often maintained by DDNS)
# as the public target source for game records. Can be FQDN or single label.
# Examples: home.cobyas.xyz or home
PUBLIC_IP_SOURCE_RECORD=

# If true, PUBLIC_IP_SOURCE_RECORD always wins over AMP target values.
# If false, it is only used when AMP target is private/loopback/missing.
PREFER_PUBLIC_IP_SOURCE=true

# Optional UPnP port forwarding (Debian host/router must support UPnP).
UPNP_ENABLED=false
# Comma-separated protocols to map for each detected game port.
UPNP_PROTOCOLS=tcp
# Enable verbose UPnP diagnostics (desired vs existing, conflicts, source row counts).
UPNP_DEBUG=false
# Optional fixed internal client IP; leave blank to auto-use gateway LAN address.
UPNP_INTERNAL_CLIENT=
# Prefix for managed UPnP mappings so stale entries can be cleaned safely.
UPNP_DESCRIPTION_PREFIX=amp-sync-upnp:
# Lease time in seconds (0 = permanent, if router supports it).
UPNP_LEASE_SECONDS=0

# Optional: comma-separated list of instance names to ignore
IGNORE_INSTANCE_NAMES=
